{
  "name": "@koralabs/handles-decentralized-minting",
  "version": "2.0.2",
  "license": "MIT",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf lib/ && tsc",
    "lint": "concurrently \"cd smart-contract && aiken fmt --check\" \"npx eslint './src/**/*.{ts,mjs}' --max-warnings=0\"",
    "test": "vitest run",
    "test:aiken": "cd smart-contract &&  aiken check",
    "deployment-plan:preview": "NETWORK=preview tsx scripts/generateDeploymentPlan.ts --desired deploy/preview/decentralized-minting.yaml --artifacts-dir /tmp/decentralized-minting-plan",
    "deployment-plan:preprod": "NETWORK=preprod tsx scripts/generateDeploymentPlan.ts --desired deploy/preprod/decentralized-minting.yaml --artifacts-dir /tmp/decentralized-minting-plan"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/koralabs/decentralized-minting.git"
  },
  "dependencies": {
    "@aiken-lang/merkle-patricia-forestry": "^1.2.0",
    "@blockfrost/blockfrost-js": "^6.0.0",
    "@cardano-sdk/core": "^0.46.12",
    "@cardano-sdk/input-selection": "^0.14.28",
    "@cardano-sdk/tx-construction": "^0.28.10",
    "@koralabs/kora-labs-common": "^5.1.41",
    "@stricahq/bip32ed25519": "^1.1.2",
    "ansi-colors": "^4.1.3",
    "cli-progress": "^3.12.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.5.0",
    "flatted": "^3.3.3",
    "prompts": "^2.4.2",
    "scalus": "^0.15.0",
    "ts-res": "^1.3.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.10.6",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "10.2.2"
  }
}
